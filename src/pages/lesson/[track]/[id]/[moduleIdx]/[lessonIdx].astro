---
import Layout from '../../../../../layouts/Layout.astro';
import LessonPlayer from '../../../../../views/LessonPlayer.tsx';

const { track, id, moduleIdx, lessonIdx } = Astro.params;
---

<Layout title={`Lesson | BCA Learn`}>
  <LessonPlayer 
    track={track as string} 
    id={id as string} 
    moduleIdx={moduleIdx as string} 
    lessonIdx={lessonIdx as string} 
    client:load 
  />
</Layout>